<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sainik Gift & Stationery Store</title>

<style>

body{
font-family: Arial;
margin:0;
background:#f4f4f4;
}

header{
background:#222;
color:white;
padding:20px;
text-align:center;
}

.container{
display:grid;
grid-template-columns:repeat(auto-fit,minmax(220px,1fr));
gap:20px;
padding:30px;
}

.product{
background:white;
padding:15px;
border-radius:10px;
text-align:center;
box-shadow:0 3px 10px rgba(0,0,0,0.1);
}

.product img{
width:100%;
height:200px;
object-fit:cover;
border-radius:8px;
}

.price{
color:green;
font-size:20px;
margin:10px 0;
}

button{
background:#25D366;
border:none;
padding:10px 15px;
color:white;
font-size:16px;
border-radius:5px;
cursor:pointer;
}

button:hover{
background:#1ebc59;
}

footer{
background:#222;
color:white;
text-align:center;
padding:15px;
}

</style>
</head>

<body>

<header>
<h1>Sainik Gift & Stationery</h1>
<p>Best Gifts, Stationery & Sports Items</p>
</header>

<div class="container">

<div class="product">
<img src="https://images.unsplash.com/photo-1580910051074-3eb694886505">
<h3>Notebook</h3>
<p class="price">₹120</p>
<button onclick="order('Notebook ₹120')">Buy on WhatsApp</button>
</div>

<div class="product">
<img src="https://images.unsplash.com/photo-1588072432836-e10032774350">
<h3>Pen Set</h3>
<p class="price">₹80</p>
<button onclick="order('Pen Set ₹80')">Buy on WhatsApp</button>
</div>

<div class="product">
<img src="https://images.unsplash.com/photo-1603570419989-0c4c4c71b6a1">
<h3>Photo Frame</h3>
<p class="price">₹250</p>
<button onclick="order('Photo Frame ₹250')">Buy on WhatsApp</button>
</div>

<div class="product">
<img src="https://images.unsplash.com/photo-1596462502278-27bfdc403348">
<h3>Cricket Bat</h3>
<p class="price">₹850</p>
<button onclick="order('Cricket Bat ₹850')">Buy on WhatsApp</button>
</div>

</div>

<footer>
<p>Contact: 8077687569</p>
<p>Address: A 404 SEC 11 AVAS VIKAS COLONY AGRA</p>
</footer>

<script>

function order(product){
let phone = "918077687569";
let message = "I want to order " + product;
let url = "https://wa.me/" + phone + "?text=" + encodeURIComponent(message);
window.open(url);
}

</script>

</body>
</html>
